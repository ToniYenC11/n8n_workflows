      ],
      "id": "f89c91f4-b168-49ef-92c2-ef08961f8057"
    },
    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\nconst passSlips = [];\n\nconst tbodyMatch = html.match(/<tbody>([\\s\\S]*?)<\\/tbody>/);\n\nif (tbodyMatch) {\n    const rows = tbodyMatch[1].match(/<tr[^>]*>([\\s\\S]*?)<\\/tr>/g);\n    \n    if (rows) {\n        for (const row of rows) {\n            const cells = [];\n            const tdRegex = /<td[^>]*>([\\s\\S]*?)<\\/td>/g;\n            let tdMatch;\n            \n            while ((tdMatch = tdRegex.exec(row)) !== null) {\n                cells.push(tdMatch[1].replace(/<[^>]*>/g, '').trim());\n            }\n\n            const idMatch = row.match(/id=(\\d+)/);\n            const id = idMatch ? idMatch[1] : null;\n            \n            if (cells.length >= 7 && id) {\n                const destination = cells[5];\n                const status = cells[6];\n                if (destination === \"Alternative Work Arrangement\" && (status === 'Approved as Official' || status === 'Pending for Approval')) {\n                    passSlips.push({\n                        json: {\n                            id: id,\n                            startDate: cells[0],\n                            endDate: cells[1],\n                        }\n                    });\n                }\n            }\n        }\n    }\n}\n\nreturn passSlips;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
