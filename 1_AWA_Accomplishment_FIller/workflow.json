      "id": "3de4acfb-3c31-4cbb-a916-bcf24ab14bc1",
      "name": "10. Generate Automatic Download Link of the Form Completed"
    },
    {
      "parameters": {
        "jsCode": "const today = new Date();\n\nconst day = today.getDate();\nconst lastDay = new Date(\n    today.getFullYear(),\n    today.getMonth() + 1,\n    0\n).getDate();\n\nconst shouldRun =\n    day === 13 ||\n    day === 15 ||\n    day === lastDay - 3 ||\n    day === lastDay - 1;\n\nif (!shouldRun) {\n    return [];\n}\n\nreturn items;"
      },
