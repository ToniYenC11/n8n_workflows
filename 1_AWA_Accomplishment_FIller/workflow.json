      ],
      "id": "65c2c353-9182-4c23-8e1e-d09198878116"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const html = $json.data;\n\nconst purposeRegex = /for=\\\"BasePassSlip_purpose\\\"[^>]*>Purpose of Business<\\/label>[\\s\\S]*?form-control-static\\\">([\\s\\S]*?)<\\/div>/;\nconst match = html.match(purposeRegex);\n\nconst sourceItem = $('5. Get List of Pass Slips within Date').item.json;\n\nreturn {\n    json: {\n        ...sourceItem,\n        purpose: match ? match[1].trim() : \"Purpose not found\"\n    }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -272,
        96
      ],
      "id": "fd048c47-e17e-4622-b1c3-68a56743484f",
      "name": "7. Extract Purpose of Business"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const purpose = $json.purpose || '';\n\nconst normalized = purpose.replace(/\\r?\\n/g, ' ');\nconst items = normalized\n  .split(/(?:^|\\s)-\\s+/)\n  .map(s => s.trim())\n  .filter(s => s.length > 0);\n\nreturn {\n    json: {\n        ...$json,\n        purposeList: items\n    }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        96
      ],
      "id": "0b1726a0-c000-417e-86ee-36a879452e26",
      "name": "8. Format \"purpose\" as lists"
    },
    {
      "parameters": {
        "jsCode": "const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];\n\nfunction parseErpDate(str) {\n    const m = str.match(/^([A-Za-z]+)\\s+(\\d{1,2}),\\s+(\\d{4})$/);\n    if (!m) throw new Error(`Unparseable date: ${str}`);\n    const monthIndex = MONTHS.findIndex(mo => mo.toLowerCase() === m[1].toLowerCase());\n    return new Date(Date.UTC(parseInt(m[3]), monthIndex, parseInt(m[2])));\n}\nfunction formatErpDate(date) {\n    return `${MONTHS[date.getUTCMonth()].toUpperCase()} ${date.getUTCDate()}, ${date.getUTCFullYear()}`;\n}\n\nconst items = $input.all();\nconst rows = [];\nfor (const item of items) {\n    const { startDate, endDate, purposeList } = item.json;\n    const cursor = parseErpDate(startDate);\n    const end = parseErpDate(endDate);\n    while (cursor <= end) {\n        rows.push({ duration: '1 DAY', workAssignment: purposeList, date: formatErpDate(cursor), accomplishments: '' });\n        cursor.setUTCDate(cursor.getUTCDate() + 1);\n    }\n}\nrows.sort((a, b) => parseErpDate(a.date) - parseErpDate(b.date));\n\nlet dateRange = '';\n\nif (rows.length) {\n    const firstDate = parseErpDate(rows[0].date);\n\n    const year = firstDate.getUTCFullYear();\n    const month = firstDate.getUTCMonth();\n\n    let periodStart, periodEnd;\n\n    if (firstDate.getUTCDate() <= 15) {\n        // First payroll period (1–15)\n        periodStart = new Date(Date.UTC(year, month, 1));\n        periodEnd = new Date(Date.UTC(year, month, 15));\n    } else {\n        // Second payroll period (16–end of month)\n        periodStart = new Date(Date.UTC(year, month, 16));\n        periodEnd = new Date(Date.UTC(year, month + 1, 0)); // Last day of month\n    }\n\n    dateRange = `${formatErpDate(periodStart)} - ${formatErpDate(periodEnd)}`;\n}\n\nreturn [{ json: { rows, date_range: dateRange } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
